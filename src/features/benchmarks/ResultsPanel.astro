---
import SectionLede from "./SectionLede.astro";
import {
  displayNumber,
  displayRate,
  missingEvidence,
  outcomePercent,
  roleLabels,
  scoreReceipt,
  scoredSystems,
} from "./model";
import { sectionCopy } from "./sections";

const deltaPoints = Math.abs(scoreReceipt.delta_vs_cold.critical_meaning_rate) * 100;
const preppedMeaning = scoreReceipt.systems["1321-prepped"].headline.critical_meaning;
const coldMeaning = scoreReceipt.systems["1321-cold"].headline.critical_meaning;
const preservedUnitGap = coldMeaning.passes - preppedMeaning.passes;
---

<section
  class="instrument-panel results-panel"
  id="panel-results"
  role="tabpanel"
  aria-labelledby="tab-results"
  tabindex="0"
  data-bench-panel="results"
  hidden
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.results} />

    <div class="section-body">
      <div class="result-reading" role="note">
        <span>run-007 · one scored hard clip</span>
        <strong>Cold leads critical meaning by {preservedUnitGap} of {coldMeaning.total} units.</strong>
        <p>That is {displayNumber(deltaPoints, { maximumFractionDigits: 1 })} percentage points on this run. It is not a composite winner or a full-pack rank.</p>
      </div>

      <div class="scored-results" aria-label="Scored run-007 system results">
        {scoredSystems.map((system) => {
          const headline = system.result.headline;
          const outcomes = headline.critical_outcomes;
          return (
            <article class="result-card">
              <header>
                <div><span>{roleLabels[system.role] ?? system.role}</span><h3>{system.label}</h3></div>
                <span class="state-chip state-measured"><span aria-hidden="true">●</span>Scored</span>
              </header>
              <div class="result-headlines">
                <div>
                  <strong>{headline.critical_meaning.passes} / {headline.critical_meaning.total}</strong>
                  <span>Critical meaning preserved</span>
                </div>
                <div>
                  <strong>{displayRate(headline.critical_meaning.rate)}</strong>
                  <span>Same 13-unit denominator</span>
                </div>
                <div>
                  <strong>{headline.catastrophic.count} / {headline.catastrophic.denominator}</strong>
                  <span>Catastrophic among emitted</span>
                </div>
              </div>
              <div
                class="outcome-bar"
                role="img"
                aria-label={`${system.label}: ${outcomes.correct} correct, ${outcomes.wrong} wrong, ${outcomes.withheld} withheld, ${outcomes.missing} missing`}
              >
                <span class="outcome-correct" style={`width:${outcomePercent(outcomes.correct, outcomes.total)}`}></span>
                <span class="outcome-wrong" style={`width:${outcomePercent(outcomes.wrong, outcomes.total)}`}></span>
                <span class="outcome-withheld" style={`width:${outcomePercent(outcomes.withheld, outcomes.total)}`}></span>
                <span class="outcome-missing" style={`width:${outcomePercent(outcomes.missing, outcomes.total)}`}></span>
              </div>
              <dl class="outcome-values">
                <div class="outcome-correct"><dt>Correct</dt><dd>{outcomes.correct}</dd></div>
                <div class="outcome-wrong"><dt>Wrong</dt><dd>{outcomes.wrong}</dd></div>
                <div class="outcome-withheld"><dt>Withheld</dt><dd>{outcomes.withheld}</dd></div>
                <div class="outcome-missing"><dt>Missing</dt><dd>{outcomes.missing}</dd></div>
              </dl>
              {system.id === "1321-prepped" && (
                <p class="result-note">Six withholds explain part of the lower meaning rate. They are not credited as meaning-preserved.</p>
              )}
            </article>
          );
        })}
      </div>

      <div class="missing-result-strip" aria-label="Benchmark evidence still missing">
        {missingEvidence.map((item) => (
          <article>
            <span>Missing</span>
            <strong>{item.label}</strong>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
