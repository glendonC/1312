---
import SectionLede from "./SectionLede.astro";
import { evidenceRows } from "./model";
import { sectionCopy } from "./sections";
---

<section
  class="instrument-panel evidence-panel"
  id="panel-evidence"
  role="tabpanel"
  aria-labelledby="tab-evidence"
  tabindex="0"
  data-bench-panel="evidence"
  hidden
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.evidence} />

    <div class="section-body">
      <div class="evidence-board">
        <div class="board-summary">
          <div>
            <strong>1</strong>
            <span>scored clip</span>
          </div>
          <p>One hard clip is scored. Two frozen controls remain unrun.</p>
        </div>

        <div class="evidence-matrix" role="table" aria-label="Evidence readiness by frozen clip">
          <div class="matrix-row matrix-head" role="row">
            <span role="columnheader">Clip</span>
            <span role="columnheader">Source</span>
            <span role="columnheader">Gold</span>
            <span role="columnheader">Capture</span>
            <span role="columnheader">Labels</span>
            <span role="columnheader">Score</span>
          </div>
          {evidenceRows.map((row) => (
            <div class="matrix-row" role="row">
              <span class="matrix-label" role="rowheader">{row.label}</span>
              {(["source", "gold", "capture", "labels", "score"] as const).map((field) => (
                <span
                  class:list={["matrix-cell", row[field] ? "is-ready" : "is-missing"]}
                  role="cell"
                  aria-label={`${row.label} ${field}: ${row[field] ? "ready" : "missing"}`}
                >{row[field] ? "✓" : ""}</span>
              ))}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
