---
import SectionLede from "./SectionLede.astro";
import { comparisonConditions, roleLabels, scoreReceipt } from "./model";
import { sectionCopy } from "./sections";

const prepped = scoreReceipt.systems["1321-prepped"].headline;
const cold = scoreReceipt.systems["1321-cold"].headline;
const comparisonNotes = [
  {
    index: "01",
    title: "The measured comparison",
    copy: `Prepared and cold share the frozen hard clip and ${cold.critical_meaning.total}-unit denominator. Cold leads critical meaning on this run.`,
  },
  {
    index: "02",
    title: "What abstention means",
    copy: `Prepared withheld ${prepped.critical_outcomes.withheld} of ${prepped.critical_outcomes.total} units. Those units are kept separate and are not credited as meaning-preserved.`,
  },
  {
    index: "03",
    title: "What is not comparable yet",
    copy: "There is no local-control score, YouTube auto receipt, or repeat-run series to compare.",
  },
];
---

<section
  class="instrument-panel compare-panel"
  id="panel-compare"
  role="tabpanel"
  aria-labelledby="tab-compare"
  tabindex="0"
  data-bench-panel="compare"
  hidden
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.compare} />

    <div class="section-body">
      <div class="same-reel-rule">
        <span>Same scored hard clip</span>
        <span aria-hidden="true">──────────────────</span>
        <span>Prepared vs cold only</span>
      </div>

      <div class="condition-board" aria-label="Measured and missing comparison conditions">
        {comparisonConditions.map((condition, index) => (
          <article data-system-role={condition.role}>
            <div class="condition-topline">
              <span>[{String(index + 1).padStart(2, "0")}]</span>
              <span class:list={["state-chip", condition.status === "measured" ? "state-measured" : "state-missing"]}>
                <span aria-hidden="true">{condition.status === "measured" ? "●" : "▨"}</span>
                {condition.statusLabel}
              </span>
            </div>
            <span class="condition-role">{roleLabels[condition.role] ?? condition.role}</span>
            <h3>{condition.label}</h3>
            <ul class="tag-list" aria-label={`${condition.label} evidence or inputs`}>
              {condition.inputs.map((input) => <li>{input}</li>)}
            </ul>
            <p><span>{condition.meta}</span></p>
          </article>
        ))}
      </div>

      <div class="comparison-notes" aria-label="How to read the comparison">
        {comparisonNotes.map((note) => (
          <article>
            <span>{note.index}</span>
            <div><h3>{note.title}</h3><p>{note.copy}</p></div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
