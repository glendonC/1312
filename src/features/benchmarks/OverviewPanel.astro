---
import SectionLede from "./SectionLede.astro";
import { displayRate, overviewFacts, scoreReceipt } from "./model";
import { sectionCopy } from "./sections";

const prepared = scoreReceipt.systems["1321-prepped"].headline.critical_meaning;
const cold = scoreReceipt.systems["1321-cold"].headline.critical_meaning;
---

<section
  class="instrument-panel overview-panel"
  id="panel-overview"
  role="tabpanel"
  aria-labelledby="tab-overview"
  tabindex="0"
  data-bench-panel="overview"
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.overview} size="hero" />

    <div class="section-body">
      <div class="snapshot-scores" aria-label={`Moments preserved out of ${overviewFacts.criticalUnits}`}>
        <article class="snapshot-score is-cold">
          <div class="snapshot-topline">
            <span>No preparation</span>
            <em class="snapshot-flag">Never stayed silent</em>
          </div>
          <strong>{cold.passes}<small> / {cold.total}</small></strong>
          <div class="snapshot-meter" aria-label={`${Math.round(cold.rate * 100)} percent`}>
            <span style={`width:${cold.rate * 100}%`}></span>
          </div>
          <p>{displayRate(cold.rate)} preserved. Answered every time, {overviewFacts.coldWrong} of them wrong.</p>
        </article>
        <article class="snapshot-score is-prepared">
          <div class="snapshot-topline">
            <span>Prepared</span>
            <em class="snapshot-flag">Stayed silent {overviewFacts.preparedWithheld} times</em>
          </div>
          <strong>{prepared.passes}<small> / {prepared.total}</small></strong>
          <div class="snapshot-meter" aria-label={`${Math.round(prepared.rate * 100)} percent`}>
            <span style={`width:${prepared.rate * 100}%`}></span>
          </div>
          <p>{displayRate(prepared.rate)} preserved. Answered {prepared.total - overviewFacts.preparedWithheld} times, {overviewFacts.preparedWrong} of them wrong.</p>
        </article>
      </div>

      <dl class="snapshot-facts">
        <div>
          <dt>Score gap</dt>
          <dd>&minus;{overviewFacts.preparedShortfall}<small> units</small></dd>
          <p>Prepared preserved fewer</p>
        </div>
        <div>
          <dt>Coverage</dt>
          <dd>{overviewFacts.scoredClips}<small> / {overviewFacts.totalClips} clips</small></dd>
          <p>{overviewFacts.totalClips - overviewFacts.scoredClips} not yet scored</p>
        </div>
        <div>
          <dt>Reviewers</dt>
          <dd>{overviewFacts.reviewers}</dd>
          <p>Blinded human review</p>
        </div>
        <div>
          <dt>Serious errors</dt>
          <dd>{overviewFacts.catastrophic}</dd>
          <p>None on either side</p>
        </div>
      </dl>
    </div>
  </div>
</section>
