---
import { freezeReceipt, labelsReceipt, scoreReceipt } from "./model";

const prepped = scoreReceipt.systems["1321-prepped"].headline.critical_meaning;
---

<section class="bench-summary" aria-label="Benchmark summary">
  <article class="summary-question">
    <span>Observed result</span>
    <strong>Cold leads critical meaning on run-007.</strong>
    <p>One scored hard clip. No full-pack or repeat-run claim.</p>
  </article>
  <article>
    <span>Frozen pack</span>
    <strong>{freezeReceipt.clips.length}</strong>
    <p>Gold clips</p>
  </article>
  <article>
    <span>Scored clips</span>
    <strong>1<small> / {freezeReceipt.clips.length}</small></strong>
    <p>Hard clip only</p>
  </article>
  <article>
    <span>Review</span>
    <strong>{labelsReceipt.reviewers.length}</strong>
    <p>Blinded reviewers</p>
  </article>
  <article class="summary-performance is-measured">
    <span>Prepared meaning</span>
    <strong>{prepped.passes}<small> / {prepped.total}</small></strong>
    <p>Critical units preserved</p>
  </article>
</section>
