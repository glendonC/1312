---
import { getCollection, render } from "astro:content";
import GlassNav from "../../components/GlassNav.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("journey");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { type, clip, run, delta, date, title, description } = post.data;

const studioHref = run ? `/studio/?run=${encodeURIComponent(run)}` : "/studio/";
const hasLinks = Boolean(clip || run || type === "score" || delta);
---

<SiteLayout title={`${title} | 1321`} description={description}>
  <GlassNav />
  <main class="interior-page">
    <article class="article-shell">
      <header>
        <p class="eyebrow">Field note</p>
        <div class="note-meta">
          <span class={`type-badge type-${type}`}>{type}</span>
          <time datetime={date.toISOString()}>
            {
              date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
        </div>
        <h1>{title}</h1>
        <p>{description}</p>
        {
          hasLinks && (
            <dl class="note-links">
              {clip && (
                <>
                  <dt>Clip</dt>
                  <dd>
                    <code>{clip}</code>
                  </dd>
                </>
              )}
              {run && (
                <>
                  <dt>Run</dt>
                  <dd>
                    <a href={studioHref}>
                      <code>{run}</code>
                    </a>
                  </dd>
                </>
              )}
              {delta && (
                <>
                  <dt>Delta</dt>
                  <dd>{delta}</dd>
                </>
              )}
              {type === "score" && (
                <>
                  <dt>Scores</dt>
                  <dd>
                    <a href="/benchmarks/">Benchmarks</a>
                  </dd>
                </>
              )}
            </dl>
          )
        }
      </header>
      <div class="article-body">
        <Content />
      </div>
      <footer class="note-footer">
        <a class="button button-primary" href={studioHref}>Open Studio</a>
        <a class="button button-secondary" href="/benchmarks/">Benchmarks</a>
        <a class="text-back" href="/journey/">All field notes</a>
      </footer>
    </article>
  </main>
</SiteLayout>
