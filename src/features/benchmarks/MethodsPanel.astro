---
import SectionLede from "./SectionLede.astro";
import { labelsReceipt, outcomeStates, overviewFacts, scoreReceipt } from "./model";
import { sectionCopy } from "./sections";

const totalUnits = scoreReceipt.systems["1321-prepped"].headline.critical_meaning.total;
// Outcome vocabulary comes from one source, so Method and Results cannot drift apart.
const outcomeNames = outcomeStates.map((state) => state.label.toLowerCase()).join(", ");
const methodRows = [
  {
    id: "meaning",
    value: totalUnits,
    unit: "units",
    label: "Meaning preserved",
    measure: `Passes out of ${totalUnits}`,
    basis: "Blinded human review",
  },
  {
    id: "outcomes",
    value: outcomeStates.length,
    unit: "states",
    label: "Outcome split",
    measure: `Every moment is one of ${outcomeNames}`,
    basis: `Every one of the ${totalUnits} units`,
  },
  {
    id: "serious",
    value: overviewFacts.catastrophic,
    unit: "this test",
    label: "Serious errors",
    measure: "Errors that reverse what a speaker meant",
    basis: "Blinded human review",
  },
];
---

<section
  class="instrument-panel methods-panel"
  id="panel-methods"
  role="tabpanel"
  aria-labelledby="tab-methods"
  tabindex="0"
  data-bench-panel="methods"
  hidden
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.methods} />

    <div class="section-body">
      <dl class="method-facts">
        <div><dt>Reviewers</dt><dd>{labelsReceipt.reviewers.length}</dd></div>
        <div><dt>Review blinded</dt><dd>Yes</dd></div>
        <div><dt>Model grader</dt><dd>None</dd></div>
      </dl>

      <div class="metric-deck" aria-label="Published benchmark metrics">
        {methodRows.map((row) => (
          <article class={`metric-card metric-${row.id}`}>
            <span>{row.label}</span>
            <strong>{row.value}<small>{row.unit}</small></strong>
            {row.id === "outcomes" && (
              <div class="metric-outcome-colors" aria-hidden="true">
                <span class="outcome-correct"></span>
                <span class="outcome-wrong"></span>
                <span class="outcome-withheld"></span>
                <span class="outcome-missing"></span>
              </div>
            )}
            <footer>
              <p>{row.measure}</p>
              <small>{row.basis}</small>
            </footer>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
