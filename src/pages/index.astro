---
import { Picture } from "astro:assets";
import { Icon } from "astro-icon/components";
import GlassNav from "../components/GlassNav.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import heroBackground from "../assets/hero-background.png";
import "../styles/hero.css";
---

<SiteLayout
  title="1321 | Language intelligence for real media"
  description="Codex agents study Korean video first so captions and learning aren’t a cold guess."
>
  <main class="hero-shell">
    <Picture
      src={heroBackground}
      alt=""
      class="hero-picture"
      formats={["avif", "webp"]}
      widths={[960, 1440, 1920, 2560, 3840]}
      sizes="100vw"
      loading="eager"
      decoding="async"
    />
    <div class="hero-scrim" aria-hidden="true"></div>
    <GlassNav />

    <section class="hero-content" aria-labelledby="hero-title">
      <div class="hero-copy">
        <h1 id="hero-title">
          <span class="hero-line">Autonomous Language Intelligence</span>
          <span class="hero-line">for Real-World Media</span>
        </h1>
      </div>

      <div class="hero-aside">
        <p>
          Building the foundation for AI to understand <span class="nowrap">real-world</span> media
          through autonomous,{" "}
          <span class="nowrap">self-improving</span>{" "}
          <span class="hero-closing">
            <span class="nowrap">investigation.</span>{" "}
            <a class="button button-primary cta-inline" href="/studio/">
              <span class="cta-content">
                View demo
                <Icon class="cta-icon" name="ph:play-fill" aria-hidden="true" />
              </span>
            </a>
          </span>
        </p>
      </div>
    </section>
  </main>
</SiteLayout>
