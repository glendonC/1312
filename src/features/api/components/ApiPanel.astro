---
import ApiCopyButton from "./ApiCopyButton.astro";

interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<figure class="api-panel">
  <figcaption>
    <span class="api-panel-title">{title}</span>
    <ApiCopyButton ariaLabel={`Copy ${title}`} />
  </figcaption>
  <pre><code>{body}</code></pre>
</figure>
