---
import ApiPanel from "../components/ApiPanel.astro";
import { BASE_URL, CURL_DISPLAY } from "../model.ts";
---

<header class="api-hero">
  <h1>API reference</h1>
  <p class="api-lede">
    The <code>/v1</code> REST surface of the 1321 runtime host: media understanding your pipeline
    can verify. Studio and agentic video editors are both clients of the same API.
  </p>
  <div class="api-meta">
    <span class="api-meta-label">Base URL</span>
    <code>{BASE_URL}</code>
    <span class="api-meta-note">self-hosted</span>
  </div>
</header>

<section class="api-section" aria-label="Make the first call">
  <h2>Make the first call</h2>
  <div class="api-split">
    <ol class="api-steps">
      <li>
        Start the host: <code>npm run runtime:host</code>. It binds <code>127.0.0.1:4312</code> and
        prints a bearer token on stdout.
      </li>
      <li>
        Send that token as <code>Authorization: Bearer</code> on every request. Details
        under <a href="/api/authentication/">Authentication</a>.
      </li>
      <li>
        List registered <a href="/api/sources/">sources</a>, then plan and start a bounded study
        and poll its journal under <a href="/api/runtime/">Runtime lifecycle</a>.
      </li>
    </ol>
    <div class="api-panels">
      <ApiPanel title="First call" body={CURL_DISPLAY} />
    </div>
  </div>
</section>
