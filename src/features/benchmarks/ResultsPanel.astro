---
import SectionLede from "./SectionLede.astro";
import {
  displayNumber,
  displayRate,
  outcomeClass,
  outcomePercent,
  outcomeStates,
  report,
  reportIsScored,
  resultBySystem,
  roleLabels,
} from "./model";
import { sectionCopy } from "./sections";
---

<section
  class="instrument-panel results-panel"
  id="panel-results"
  role="tabpanel"
  aria-labelledby="tab-results"
  tabindex="0"
  data-bench-panel="results"
  hidden
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.results} />

    <div class="section-body">
      {!reportIsScored ? (
        <>
          <div class="empty-scorecard" role="note" aria-label="No benchmark result is measured">
            <div class="empty-score-topline"><span>Lines that matter, preserved</span><span>Awaiting frozen evidence</span></div>
            <span class="null-hero" aria-hidden="true"></span>
            <h3>Not measured yet</h3>
            <p>A single rate appears here only after real clips, a frozen answer key, captured outputs, and blind review exist.</p>
            <div class="empty-outcome-track" aria-hidden="true"></div>
            <span class="empty-track-label">No outcome split yet</span>
            <dl>
              <div><dt>Lines that matter</dt><dd><span class="null-mark" aria-hidden="true"></span></dd></div>
              <div><dt>Serious errors shown</dt><dd><span class="null-mark" aria-hidden="true"></span></dd></div>
              <div><dt>Time to first caption</dt><dd><span class="null-mark" aria-hidden="true"></span></dd></div>
            </dl>
          </div>

          <div class="outcome-key" aria-label="How to read the four outcomes">
            {outcomeStates.map((outcome, index) => (
              <article class={outcomeClass[outcome.id]}>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{outcome.label}</h3>
                <p>{outcome.definition}</p>
              </article>
            ))}
          </div>
        </>
      ) : (
        <div class="scored-results" aria-label="Scored system results">
          {report.systems.map((system) => {
            const result = resultBySystem.get(system.id)!;
            const outcomes = result.headline.critical_outcomes;
            return (
              <article class="result-card">
                <header>
                  <div><span>{roleLabels[system.role] ?? system.role}</span><h3>{system.label}</h3></div>
                  <span class="state-chip state-measured"><span aria-hidden="true">●</span>Measured</span>
                </header>
                <div class="result-headlines">
                  <div><strong>{displayRate(result.headline.critical_meaning.rate)}</strong><span>Lines that matter</span></div>
                  <div><strong>{displayNumber(result.headline.catastrophic.count)}</strong><span>Serious errors</span></div>
                  <div><strong>{displayNumber(result.headline.latency.first_usable_s, { maximumFractionDigits: 1 })}</strong><span>Seconds to first caption</span></div>
                </div>
                <div
                  class="outcome-bar"
                  role="img"
                  aria-label={`${system.label}: ${displayNumber(outcomes.correct)} shown & right, ${displayNumber(outcomes.wrong)} shown & wrong, ${displayNumber(outcomes.withheld)} held back, ${displayNumber(outcomes.missing)} missed`}
                >
                  <span class="outcome-correct" style={`width:${outcomePercent(outcomes.correct, outcomes.total)}`}></span>
                  <span class="outcome-wrong" style={`width:${outcomePercent(outcomes.wrong, outcomes.total)}`}></span>
                  <span class="outcome-withheld" style={`width:${outcomePercent(outcomes.withheld, outcomes.total)}`}></span>
                  <span class="outcome-missing" style={`width:${outcomePercent(outcomes.missing, outcomes.total)}`}></span>
                </div>
                <dl class="outcome-values">
                  <div class="outcome-correct"><dt>Shown &amp; right</dt><dd>{displayNumber(outcomes.correct)}</dd></div>
                  <div class="outcome-wrong"><dt>Shown &amp; wrong</dt><dd>{displayNumber(outcomes.wrong)}</dd></div>
                  <div class="outcome-withheld"><dt>Held back</dt><dd>{displayNumber(outcomes.withheld)}</dd></div>
                  <div class="outcome-missing"><dt>Missed</dt><dd>{displayNumber(outcomes.missing)}</dd></div>
                </dl>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </div>
</section>
