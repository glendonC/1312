---
import type { ApiEndpointGroup } from "../model.ts";
import { endpointGroupMarkdown } from "../pageMarkdown.ts";
import ApiEndpoint from "./ApiEndpoint.astro";
import ApiPageHeader from "./ApiPageHeader.astro";

interface Props {
  group: ApiEndpointGroup;
}

const { group } = Astro.props;
---

<section class="api-section" aria-label={group.title}>
  <ApiPageHeader
    title={group.title}
    description={group.note}
    markdown={endpointGroupMarkdown(group)}
  />
  <div class="api-endpoints">
    {group.endpoints.map((endpoint) => (
      <ApiEndpoint endpoint={endpoint} />
    ))}
  </div>
</section>
