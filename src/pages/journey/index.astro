---
import { getCollection } from "astro:content";
import GlassNav from "../../components/GlassNav.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";

const posts = (await getCollection("journey", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
});
---

<SiteLayout
  title="Journey | 1321"
  description="Build Week field notes: what we tried, what failed, what scored."
>
  <GlassNav />
  <main class="interior-page">
    <header class="page-hero narrow">
      <p class="eyebrow">Evidence</p>
      <h1>Build Week field notes</h1>
      <p>What we tried, what failed, what scored. Jul 13–21 and after.</p>
    </header>

    <ol class="timeline-list">
      {
        posts.map((post) => (
          <li>
            <a class="timeline-row" href={`/journey/${post.id}/`}>
              <time datetime={post.data.date.toISOString()}>
                {dateFmt.format(post.data.date)}
              </time>
              <span class={`type-badge type-${post.data.type}`}>{post.data.type}</span>
              <span class="timeline-copy">
                <span class="timeline-title">{post.data.title}</span>
                <span class="timeline-claim">{post.data.description}</span>
              </span>
              {post.data.delta && <span class="timeline-delta">{post.data.delta}</span>}
            </a>
          </li>
        ))
      }
    </ol>
  </main>
</SiteLayout>
