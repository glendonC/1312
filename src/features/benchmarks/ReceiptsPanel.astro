---
import SectionLede from "./SectionLede.astro";
import {
  freezeReceipt,
  labelsReceipt,
  missingArtifacts,
  missingEvidence,
  readyArtifacts,
  receiptFiles,
  scoreReceipt,
  shortIdentity,
  workItems,
} from "./model";
import { sectionCopy } from "./sections";
---

<section
  class="instrument-panel receipts-panel"
  id="panel-receipts"
  role="tabpanel"
  aria-labelledby="tab-receipts"
  tabindex="0"
  data-bench-panel="receipts"
  hidden
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.receipts} />

    <div class="section-body">
      <div class="work-ledger">
        <div class="ledger-heading"><span>Evidence step</span><span>Current state</span></div>
        {workItems.map((item) => (
          <article>
            <span class={`ledger-marker state-${item.state}`} aria-hidden="true"></span>
            <div><h3>{item.label}</h3><p>{item.meta}</p></div>
            <span class={`state-chip state-${item.state}`}>
              <span aria-hidden="true">{item.state === "ready" ? "✓" : item.state === "measured" ? "●" : "▨"}</span>
              {item.stateLabel}
            </span>
          </article>
        ))}
      </div>

      <div class="receipt-stack">
        <article class="receipt-summary">
          <span>Evidence receipts present</span>
          <strong>{readyArtifacts}<small> / {receiptFiles.length}</small></strong>
          <p>{missingArtifacts} comparison receipts are explicitly absent.</p>
        </article>

        <details class="receipt-details" open>
          <summary>Receipt bindings and gaps <span>{receiptFiles.length}</span></summary>
          <ul>
            {receiptFiles.map((artifact) => (
              <li>
                <span class={`ledger-marker state-${artifact.state}`} aria-hidden="true"></span>
                <div>
                  <code>{artifact.path}</code>
                  <small>{artifact.role}</small>
                  <small class="receipt-identity">{shortIdentity(artifact.identity)}</small>
                </div>
                <span>{artifact.state === "ready" ? "Bound" : "Missing"}</span>
              </li>
            ))}
          </ul>
        </details>

        <details class="receipt-details">
          <summary>Still outside this score <span>{missingEvidence.length}</span></summary>
          <ul>
            {missingEvidence.map((item) => (
              <li>
                <span class="ledger-marker state-missing" aria-hidden="true"></span>
                <div><strong>{item.label}</strong><small>{item.detail}</small></div>
                <span>Missing</span>
              </li>
            ))}
          </ul>
        </details>
      </div>

      <div class="protocol-strip" aria-label="Protocol decisions applied to run-007">
        <div><span>Judgment</span><strong>{scoreReceipt.systems["1321-prepped"].headline.critical_meaning.total} pre-registered critical units</strong></div>
        <div><span>Review</span><strong>{labelsReceipt.reviewers.length} blinded reviewers</strong></div>
        <div><span>Judge</span><strong>{scoreReceipt.judge === null ? "No model grader" : scoreReceipt.judge}</strong></div>
        <div><span>Freeze</span><strong>{freezeReceipt.frozen_at}</strong></div>
      </div>
    </div>
  </div>
</section>
