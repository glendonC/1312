---
import SectionLede from "./SectionLede.astro";
import { displayRate, freezeReceipt, labelsReceipt, scoreReceipt } from "./model";
import { sectionCopy } from "./sections";

const prepared = scoreReceipt.systems["1321-prepped"].headline.critical_meaning;
const cold = scoreReceipt.systems["1321-cold"].headline.critical_meaning;
const scoredClips = 1;
---

<section
  class="instrument-panel overview-panel"
  id="panel-overview"
  role="tabpanel"
  aria-labelledby="tab-overview"
  tabindex="0"
  data-bench-panel="overview"
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.overview} size="hero" />

    <div class="section-body">
      <div class="snapshot-scores" aria-label="Headline benchmark scores">
        <article class="snapshot-score is-cold">
          <span>No preparation</span>
          <strong>{cold.passes}<small> / {cold.total}</small></strong>
          <div class="snapshot-meter" aria-label={`${Math.round(cold.rate * 100)} percent`}>
            <span style={`width:${cold.rate * 100}%`}></span>
          </div>
          <p>{displayRate(cold.rate)} meaning preserved</p>
        </article>
        <article class="snapshot-score is-prepared">
          <span>Prepared</span>
          <strong>{prepared.passes}<small> / {prepared.total}</small></strong>
          <div class="snapshot-meter" aria-label={`${Math.round(prepared.rate * 100)} percent`}>
            <span style={`width:${prepared.rate * 100}%`}></span>
          </div>
          <p>{displayRate(prepared.rate)} meaning preserved</p>
        </article>
      </div>

      <dl class="snapshot-facts">
        <div><dt>Lead</dt><dd>+{cold.passes - prepared.passes}<small> units</small></dd></div>
        <div><dt>Coverage</dt><dd>{scoredClips}<small> / {freezeReceipt.clips.length} clips</small></dd></div>
        <div><dt>Reviewers</dt><dd>{labelsReceipt.reviewers.length}</dd></div>
        <div><dt>Serious errors</dt><dd>0</dd></div>
      </dl>
    </div>
  </div>
</section>
