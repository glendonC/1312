---
import SectionLede from "./SectionLede.astro";
import { sectionCopy } from "./sections";

const checks = [
  { label: "Test set locked before scoring", state: "verified" },
  { label: "Both systems used the same source", state: "verified" },
  { label: "Human review completed blind", state: "verified" },
  { label: "Published score arithmetic verified", state: "verified" },
  { label: "Two control clips scored", state: "pending" },
  { label: "Public baseline scored", state: "pending" },
  { label: "Repeat-run variance measured", state: "pending" },
] as const;
const verified = checks.filter((check) => check.state === "verified").length;
const pending = checks.length - verified;
---

<section
  class="instrument-panel receipts-panel"
  id="panel-receipts"
  role="tabpanel"
  aria-labelledby="tab-receipts"
  tabindex="0"
  data-bench-panel="receipts"
  hidden
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.receipts} />

    <div class="section-body">
      <div class="audit-summary" aria-label={`${verified} verified and ${pending} pending audit checks`}>
        <div><strong>{verified}</strong><span>Verified</span></div>
        <div><strong>{pending}</strong><span>Pending</span></div>
      </div>

      <div class="audit-list" role="list" aria-label="Benchmark audit checks">
        {checks.map((check) => (
          <div class:list={["audit-row", `is-${check.state}`]} role="listitem">
            <span class="audit-marker" aria-hidden="true">{check.state === "verified" ? "✓" : ""}</span>
            <strong>{check.label}</strong>
            <span>{check.state === "verified" ? "Verified" : "Pending"}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
