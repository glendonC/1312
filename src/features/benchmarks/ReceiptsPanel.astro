---
import SectionLede from "./SectionLede.astro";
import { auditFailed, auditGroups, auditPassed, pinnedReceipts } from "./audit";
import { sectionCopy } from "./sections";

const totalChecks = auditPassed + auditFailed;
---

<section
  class="instrument-panel receipts-panel"
  id="panel-receipts"
  role="tabpanel"
  aria-labelledby="tab-receipts"
  tabindex="0"
  data-bench-panel="receipts"
  hidden
>
  <div class="section-split">
    <SectionLede copy={sectionCopy.receipts} />

    <div class="section-body">
      <div class="metric-deck" aria-label="Audit summary">
        <article class="metric-card audit-card-passed">
          <span>Checks passed</span>
          <strong>{auditPassed}<small>of {totalChecks}</small></strong>
          <footer>
            <p>Recomputed on every build</p>
            <small>Never typed in by hand</small>
          </footer>
        </article>
        <article class="metric-card audit-card-pinned">
          <span>Files pinned</span>
          <strong>{pinnedReceipts}<small>by fingerprint</small></strong>
          <footer>
            <p>Editing any file breaks the chain</p>
            <small>Recording, grades, test set, score</small>
          </footer>
        </article>
        <article class="metric-card audit-card-failed">
          <span>Failed</span>
          <strong>{auditFailed}<small>this build</small></strong>
          <footer>
            <p>A failing check stops the build</p>
            <small>So this number cannot differ</small>
          </footer>
        </article>
      </div>

      <details class="audit-details">
        <summary>
          See all {totalChecks} checks
          <span aria-hidden="true"></span>
        </summary>
        <div class="audit-groups">
          {auditGroups.map((group) => (
            <section class="audit-group">
              <h3>{group.title}</h3>
              <ul>
                {group.checks.map((check) => (
                  <li class:list={[check.passed ? "is-passed" : "is-failed"]}>
                    <span class="audit-text">{check.label}</span>
                    {!check.passed && <span class="audit-state">Failed</span>}
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </details>
    </div>
  </div>
</section>
