{
  "name": "1321",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "bench:check": "node scripts/check-bench.mjs",
    "evidence:check": "node scripts/index-recorded-evidence.mjs --run run-005 --check && node scripts/index-recorded-evidence.mjs --run run-006 --check",
    "memory:check": "node scripts/check-memory.mjs",
    "speech:check": "node --test tests/studio-speech-production.test.ts",
    "language:check": "node --test tests/studio-language-production.test.ts",
    "runtime:check": "node --test tests/studio-runtime-production.test.ts tests/studio-run-start-production.test.ts tests/studio-forecast-production.test.ts tests/studio-memory-inspection.test.ts",
    "runtime:index": "node scripts/index-runtime-observability.ts",
    "runtime:smoke:codex": "node scripts/run-local-worker.ts --source-directory public/demo/runs/run-005 --source-language-mode declared --source-language ko --target-language en --language-pack ko-v3 --output-depth evidence",
    "studio:check": "npm run build && npm run bench:check && npm run evidence:check && npm run memory:check && npm run speech:check && npm run language:check && npm run runtime:check && npm run studio:qa:list",
    "studio:qa": "playwright test",
    "studio:qa:list": "playwright test --list",
    "preview": "astro preview"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "ajv": "^8.20.0",
    "astro": "^7.0.0",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@huggingface/transformers": "4.2.0",
    "@iconify-json/ph": "^1.2.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.11.2",
    "astro-icon": "^1.1.5",
    "d3-hierarchy": "^3.1.2",
    "motion": "^12.42.2",
    "onnxruntime-node": "1.27.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  }
}
