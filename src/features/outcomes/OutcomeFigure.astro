---
// One clean emblem per Outcomes section: a single recognizable line icon in the
// section's tinted panel. Deliberately not a mechanism diagram - explaining how
// the system works is the Method page's job. Here the icon just marks the
// outcome, needs no decoding, and inherits its palette ink via currentColor.
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
}
const { id } = Astro.props;

// Phosphor (ph) icons, already a dependency. One emblem per outcome.
const icons: Record<string, string> = {
  investigation: "ph:magnifying-glass", // investigate the uncertain lines
  "media-first": "ph:waveform", // start from the media itself
  "adaptive-effort": "ph:target", // effort aimed where it is hard
  traceable: "ph:seal-check", // evidence you can trust behind every answer
  reusable: "ph:share-network", // one investigation, reused in many places
  learning: "ph:graduation-cap", // understanding becomes a way to learn
};

const icon = icons[id] ?? "ph:circle";
---

<div class="outcomes-figure">
  <Icon name={icon} class="outcomes-figure-icon" aria-hidden="true" />
</div>

<style>
  /* Palette variables inherit from the ancestor section's data-palette. */
  .outcomes-figure {
    margin-top: clamp(20px, 2.4vw, 34px);
    width: min(100%, 16rem);
    aspect-ratio: 16 / 12;
    display: grid;
    place-items: center;
    border-radius: var(--squircle-radius);
    background: var(--palette-soft);
    color: var(--palette-ink);
  }

  .outcomes-figure-icon {
    width: clamp(54px, 34%, 84px);
    height: auto;
  }

  @media (max-width: 900px) {
    .outcomes-figure {
      width: min(100%, 13rem);
      margin-top: clamp(14px, 4vw, 22px);
    }
  }
</style>
