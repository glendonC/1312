---
import ApiPager from "./components/ApiPager.astro";
import ApiSidebar from "./components/ApiSidebar.astro";
// Direct imports so Vite invalidates each sheet; a CSS @import barrel can serve stale CSS until HMR.
import "./styles/layout.css";
import "./styles/sidebar.css";
import "./styles/reference.css";
import "./styles/panels.css";
import "./styles/sections.css";

interface Props {
  activeSlug: string;
  eyebrow?: string;
}

const { activeSlug, eyebrow } = Astro.props;
---

<div class="api-shell">
  <ApiSidebar activeSlug={activeSlug} />
  <div class="api-content">
    {eyebrow && <p class="api-kicker">{eyebrow}</p>}
    <slot />
    <ApiPager activeSlug={activeSlug} />
  </div>
</div>

<script>
  const fadeState = window as Window & { __apiFadeBound?: boolean };
  if (!fadeState.__apiFadeBound) {
    const updatePanelFades = (code: HTMLElement) => {
      const pre = code.querySelector("pre");
      if (!pre) return;
      const fuzz = 2;
      code.toggleAttribute("data-fade-left", pre.scrollLeft > fuzz);
      code.toggleAttribute(
        "data-fade-right",
        pre.scrollLeft + pre.clientWidth < pre.scrollWidth - fuzz,
      );
      code.toggleAttribute("data-fade-top", pre.scrollTop > fuzz);
      code.toggleAttribute(
        "data-fade-bottom",
        pre.scrollTop + pre.clientHeight < pre.scrollHeight - fuzz,
      );
    };
    const updateAllPanelFades = () => {
      for (const code of document.querySelectorAll<HTMLElement>("[data-api-code]")) {
        updatePanelFades(code);
      }
    };
    // Scroll and toggle do not bubble; capture observes them from any panel.
    document.addEventListener(
      "scroll",
      (event) => {
        const code = (event.target as Partial<HTMLElement> | null)?.closest?.("[data-api-code]");
        if (code instanceof HTMLElement) updatePanelFades(code);
      },
      true,
    );
    document.addEventListener(
      "toggle",
      () => {
        updateAllPanelFades();
        // Endpoint <details> ease open over ~300ms; re-measure once settled.
        window.setTimeout(updateAllPanelFades, 360);
      },
      true,
    );
    window.addEventListener("resize", updateAllPanelFades);
    updateAllPanelFades();
    document.fonts?.ready.then(updateAllPanelFades);
    fadeState.__apiFadeBound = true;
  }

  const copyState = window as Window & { __apiCopyBound?: boolean };
  if (!copyState.__apiCopyBound) {
    const flash = (button: HTMLButtonElement, idle: string) => {
      const label = button.querySelector<HTMLElement>("[data-api-copy-label]");
      if (label) label.textContent = "Copied";
      else button.textContent = "Copied";
      button.classList.add("is-copied");
      window.setTimeout(() => {
        if (label) label.textContent = idle;
        else button.textContent = idle;
        button.classList.remove("is-copied");
      }, 1400);
    };

    document.addEventListener("click", async (event) => {
      const pageButton = (event.target as HTMLElement).closest<HTMLButtonElement>(
        "[data-api-copy-page]",
      );
      if (pageButton) {
        const source = pageButton
          .closest(".api-page-header, .api-hero")
          ?.querySelector<HTMLScriptElement>("[data-api-copy-source]");
        if (!source?.textContent) return;
        try {
          const markdown = JSON.parse(source.textContent) as string;
          await navigator.clipboard.writeText(markdown);
        } catch {
          return;
        }
        flash(pageButton, "Copy page");
        return;
      }

      const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-api-copy]");
      if (!button) return;
      const code = button.closest("figure")?.querySelector("pre code");
      if (!code?.textContent) return;
      try {
        await navigator.clipboard.writeText(code.textContent);
      } catch {
        return;
      }
      flash(button, "Copy");
    });
    copyState.__apiCopyBound = true;
  }
</script>
