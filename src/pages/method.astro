---
import GlassNav from "../components/GlassNav.astro";
import MethodProcess from "../features/method/MethodProcess";
import SiteLayout from "../layouts/SiteLayout.astro";
import "../features/method/styles/index.css";
---

<SiteLayout
  title="Method | 1321"
  description="How 1321 turns Korean media into checked English captions."
>
  <GlassNav />
  <main class="method-page">
    <MethodProcess />
  </main>
</SiteLayout>

<script>
  import { enhanceMethodProcess } from "../features/method/enhanceMethodProcess";

  let teardownMethodProcess = () => {};

  const setupMethodProcess = () => {
    teardownMethodProcess();

    const root = document.querySelector<HTMLElement>("[data-method-process]");
    teardownMethodProcess = root ? enhanceMethodProcess(root) : () => {};
  };

  document.addEventListener("astro:page-load", setupMethodProcess);
  setupMethodProcess();
</script>
