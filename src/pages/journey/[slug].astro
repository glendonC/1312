---
import { getCollection, render } from "astro:content";
import GlassNav from "../../components/GlassNav.astro";
import { formatLogDate } from "../../features/journey/format";
import SiteLayout from "../../layouts/SiteLayout.astro";
import "../../features/journey/styles/index.css";

export async function getStaticPaths() {
  const posts = await getCollection("journey", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { type, date, title, description, author, topic } = post.data;
---

<SiteLayout title={`${title} | 1321`} description={description}>
  <GlassNav />
  <main class="journey-page journey-route-page">
    <article class="journey-reading is-visible" data-journey-article>
      <a class="journey-back" href="/journey/">
        <span class="journey-back-icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" width="15" height="15">
            <path
              d="M2.6 8h10.2M8.6 3.4 13.4 8l-4.8 4.6"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              transform="rotate(180 8 8)"
            />
          </svg>
        </span>
        <span>Build Week</span>
      </a>

      <header class="journey-reading-hero">
        <p class="journey-reading-meta">
          <time datetime={date.toISOString()}>{formatLogDate(date)}</time>
          <span class={`type-badge type-${type}`}>{type}</span>
          {topic && <span>{topic}</span>}
        </p>
        <h1>{title}</h1>
        <p class="journey-reading-description">{description}</p>
        <p class="journey-reading-byline">By {author}</p>
      </header>

      <div class="journey-reading-divider"></div>

      <div class="journey-reading-grid">
        <aside class="journey-reading-sections">
          <nav aria-label="Article sections" data-journey-toc>
            <p class="journey-rail-label">Sections</p>
          </nav>
        </aside>

        <div class="article-body journey-reading-body">
          <Content />
        </div>

        <aside class="journey-reading-references">
          <p class="journey-rail-label">References</p>
          <ol data-journey-references></ol>
        </aside>
      </div>
    </article>
  </main>

  <script>
    import { bindJourneyArticleEnhancements } from "../../features/journey/enhanceArticle";
    bindJourneyArticleEnhancements();
  </script>
</SiteLayout>
